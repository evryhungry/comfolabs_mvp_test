{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "DOTENV_CONFIG_PATH=.env.local nest start",
    "start:dev": "DOTENV_CONFIG_PATH=.env.local nest start --watch",
    "start:debug": "DOTENV_CONFIG_PATH=.env.local nest start --debug --watch",
    "start:prod": "DOTENV_CONFIG_PATH=.env.local node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "DOTENV_CONFIG_PATH=.env.test NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "DOTENV_CONFIG_PATH=.env.test NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:cov": "DOTENV_CONFIG_PATH=.env.test NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:debug": "DOTENV_CONFIG_PATH=.env.test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "DOTENV_CONFIG_PATH=.env.test jest --config ./test/jest-e2e.json",
    "migration:create": "npm run build && DOTENV_CONFIG_PATH=.env.local npx mikro-orm migration:create",
    "migration:up": "npm run build && DOTENV_CONFIG_PATH=.env.local npx mikro-orm migration:up",
    "migration:down": "npm run build && DOTENV_CONFIG_PATH=.env.local npx mikro-orm migration:down",
    "migration:list": "npm run build && DOTENV_CONFIG_PATH=.env.local npx mikro-orm migration:list",
    "migration:fresh": "npm run build && DOTENV_CONFIG_PATH=.env.local npx mikro-orm migration:fresh",
    "schema:update": "npm run build && DOTENV_CONFIG_PATH=.env.local npx mikro-orm schema:update --run",
    "schema:drop": "npm run build && DOTENV_CONFIG_PATH=.env.local npx mikro-orm schema:drop --run"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@mikro-orm/cli": "^6.6.7",
    "@mikro-orm/core": "^6.6.7",
    "@mikro-orm/migrations": "^6.6.7",
    "@mikro-orm/mysql": "^6.6.7",
    "@mikro-orm/nestjs": "^6.1.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.6.1",
    "mysql2": "^3.18.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "mikro-orm": {
    "configPaths": [
      "./dist/infrastructure/config/mikro-orm.config.js"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "useESM": true }]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
